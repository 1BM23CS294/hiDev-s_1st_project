/**
 * Core Philosophy: This ruleset enforces a strict private data model for owners,
 * with an exception for read-only guest access to analysis reports.
 *
 * Data Structure: Each user's data is stored under `/users/{userId}`.
 *
 * Key Security Decisions:
 * - Private Data for Owners: A user can only read and write their own documents.
 * - Guest Access: A predefined list of guest emails is granted read-only (`get`, `list`)
 *   access to the `analysisReports` collection group, allowing them to view all reports
 *   across all users. Guests cannot write any data.
 * - User Enumeration Prevention: Listing the top-level `/users` collection is
 *   disallowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the signed-in user's email is in the guest list.
     * IMPORTANT: Add the Google account emails of your guests to this list.
     * These users will have read-only access to all analysis reports.
     */
    function isGuest() {
      return isSignedIn() && request.auth.token.email in [
        // Example: 'guest-viewer@example.com',
        // Example: 'another-guest@gmail.com'
      ];
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isValidUserDocOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    function isValidUserDocOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    function isValidSubcollectionDocOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    function isValidSubcollectionDocOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }


    //-------------------------------------------------------------------------//
    // Collection Rules
    //-------------------------------------------------------------------------//

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidUserDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/resumes/{resumeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/jobDescriptions/{jobDescriptionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    // Rules for analysisReports must allow guest reads.
    match /users/{userId}/analysisReports/{analysisReportId} {
      // Owners can read and list their own reports. Guests can also read (get) any report.
      allow get, list: if isOwner(userId) || isGuest();
      // Only owners can create, update, or delete their own reports.
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    // This collection group rule allows guests to list all reports across all users.
    match /{path=**}/analysisReports/{reportId} {
      allow list: if isGuest();
    }
  }
}
